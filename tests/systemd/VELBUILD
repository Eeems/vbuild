"
socket() {
	systemdunits='
	test/bar.socket
	'
	package() {
		cd "$srcdir"
		mkdir -p test
		mv bar.socket test/
	}
}
empty() {
	postinstall() {
		true
	}
	postupgrade() {
		postinstall
	}
	package() {
		mkdir -p "$subpkgdir"
	}
}

